# Chunk 8
#| echo: false
#| warning: false
#| message: false
data %>%
pivot_longer(cols = c(Veg, Fruit),
names_to = "Diet",
values_to = "Intake") %>%
ggplot(aes(x = Intake, fill = Obese)) +
geom_bar(position = "fill") +
facet_wrap(~ Diet) +
theme_minimal() +
labs(title = "Obesity by Diet Factors",
x = "Intake (Yes/No)",
y = "Proportion")
