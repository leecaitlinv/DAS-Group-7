#| message: false
data$Obese <- factor(data$Obese)
data$AgeGroup <- factor(data$AgeGroup)
data$Sex <- factor(data$Sex)
data$Employment <- factor(data$Employment)
data$Veg <- factor(data$Veg)
data$Fruit <- factor(data$Fruit)
Question2 <- glm(
Obese ~ AgeGroup + Sex + Employment + Veg + Fruit,
data = data,
family = binomial)
summary(Question2)
# Chunk 12
#q2 models
#testing the binomial model with just the additive terms.
modelred <- glm(Obese~ Year + Sex + AgeGroup + Employment + Veg + Fruit, data = data, family = binomial)
summary(modelred)
#did backward elimination using step funciton to get the final model as:
step(modelred, direction = "backward")
