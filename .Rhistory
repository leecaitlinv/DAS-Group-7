data<-read.csv("DAProject7.csv")
library(ggplot2)
library(tidyverse)
library(tidymodels)
library(gt)
library(MASS)
library(patchwork)
library(moderndive)
library(sjPlot)
library(performance)
library(kableExtra)
data$Obese <- factor(data$Obese)
data$AgeGroup <- factor(data$AgeGroup)
data$Sex <- factor(data$Sex)
data$Employment <- factor(data$Employment)
data$Veg <- factor(data$Veg)
data$Fruit <- factor(data$Fruit)
#| echo: false
#| warning: false
#| message: false
#| fig-height: 8
#| fig-width: 6
library(dplyr)
library(tidyr)
library(ggplot2)
library(stringr)
data_long <- data %>%
mutate(across(c(Year, AgeGroup, Sex, Employment), factor)) %>%
mutate(Employment = str_wrap(as.character(Employment), width = 18)) %>%
pivot_longer(
cols = c(Year, AgeGroup, Sex, Employment),
names_to = "Variable",
values_to = "Category"
)%>%
mutate(Variable = factor(Variable, levels = c("AgeGroup", "Sex", "Year", "Employment")))
ggplot(data_long, aes(x = Category, fill = Obese)) +
geom_bar(position = "fill") +
facet_wrap(~ Variable, scales = "free_x",ncol=2) +
theme_minimal() +
labs(
title = "Obesity Distribution Across Demographic Factors",
x = "",
y = "Proportion"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
)
ggplot(data_long, aes(x = Category, fill = Obese)) +
geom_bar(position = "fill") +
facet_wrap(~ Variable, scales = "free_x", ncol = 2) +
labs(
title = "Obesity Distribution Across Demographic Factors",
x = NULL,
y = "Proportion"
) +
theme_minimal(base_size = 11) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1, size = 8),
strip.text = element_text(face = "bold"),
legend.position = "bottom",
plot.title = element_text(hjust = 0.5, face = "bold")
)
ggplot(data_long, aes(x = Category, fill = Obese)) +
geom_bar(position = "fill") +
facet_wrap(~ Variable, scales = "free_x",ncol=2) +
theme_minimal() +
labs(
title = "Obesity Distribution Across Demographic Factors",
x = "",
y = "Proportion"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1, size = 8),
legend.position = "bottom",
strip.text = element_text(face = "bold"),
plot.title = element_text(hjust = 0.5, face = "bold")
) +
theme_minimal(base_size = 11)
ggplot(data_long, aes(x = Category, fill = Obese)) +
geom_bar(position = "fill") +
facet_wrap(~ Variable, scales = "free_x",ncol=2) +
theme_minimal() +
labs(
title = "Obesity Distribution Across Demographic Factors",
x = NULL,
y = "Proportion"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1, size = 8),
legend.position = "bottom",
strip.text = element_text(face = "bold"),
plot.title = element_text(hjust = 0.5, face = "bold")
) +
theme_minimal(base_size = 11)
